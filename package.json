{
  "name": "ccmesh",
  "private": true,
  "version": "0.2.1-7",
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "node scripts/tauri.mjs dev",
    "tauri": "node scripts/tauri.mjs",
    "tauri:build": "dotenv -e .env.local -- node scripts/tauri.mjs build",
    "cargo:build": "pnpm install && cargo build --manifest-path src-tauri/Cargo.toml",
    "test": "vitest run",
    "check": "pnpm check:front && pnpm check:rust",
    "check:front": "tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --message-format=short",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "format": "eslint src --fix && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:check": "eslint src --max-warnings 0 && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "prepare": "simple-git-hooks",
    "version:set": "node scripts/update-version.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "src/**/*.{css,md,json}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ],
    "src-tauri/**/*.rs": [
      "rustfmt"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/helpers": "^0.4.0",
    "@dnd-kit/react": "^0.4.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lobehub/icons": "^5.10.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
